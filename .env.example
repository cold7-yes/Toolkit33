# Sanity configuration — get these from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"

# Random string used to authenticate the Sanity → /api/revalidate webhook.
# Generate one with: openssl rand -hex 32
SANITY_REVALIDATE_SECRET="change-me-to-a-long-random-string"
